{
  "name": "autouber",
  "version": "1.0.0",
  "description": "A Discord bot to automate Uber Eats orders.",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "register": "node src/register.js",
    "setup": "node -e \"const {downloadBrowser}=require('camoufox');downloadBrowser().then(()=>console.log('Camoufox ready'))\"",
    "test-camoufox": "node src/playwright-script.js"
  },
  "keywords": [
    "discord",
