    "eats",
    "automation",
    "camoufox"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "camoufox": "^0.1.19",
    "discord-interactions": "^3.4.0",
    "discord.js": "^14.15.3",
    "dotenv": "^17.3.1",
    "itty-router": "^4.0.27"
  },
  "devDependencies": {
    "wrangler": "^3.98.0"
  }
}
