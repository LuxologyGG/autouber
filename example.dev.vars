# Copy this file to .dev.vars and fill in your credentials.
# .dev.vars is used by `wrangler dev` for local secrets (never commit it).
# For the Node.js bot (main.js), these same vars go in .env.

DISCORD_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_application_id_here
DISCORD_PUBLIC_KEY=your_public_key_here

# Optional: restrict command registration to a specific guild (faster for dev)
# DISCORD_GUILD_ID=your_guild_id_here

# Uber Eats account password for the automation
UBER_PASSWORD=your_uber_password_here

# Set to "false" to watch the Camoufox browser during automation
HEADLESS=true

# Webhook URL for the Cloudflare Worker to trigger local Camoufox automation.
# Expose your local machine with: npx cloudflared tunnel --url http://localhost:3000
# Then set this to the tunnel URL + /order, e.g. https://abc123.trycloudflare.com/order
AUTOMATION_WEBHOOK_URL=https://your-tunnel-url.trycloudflare.com/order

# Secret shared between the Worker and the local webhook server (already in .env)
TRIGGER_SECRET=supersecret-uber-bot-key
